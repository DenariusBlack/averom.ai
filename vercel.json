<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Averom — Supplier Risk Intelligence</title>
<meta name="description" content="AI-powered supplier verification for Amazon sellers. Verify before you wire." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --gold: #C9A84C; --gold-dim: rgba(201,168,76,0.3); --gold-glow: rgba(201,168,76,0.08);
    --navy: #0D1117; --navy2: #111820; --navy3: #161E28;
    --border: rgba(201,168,76,0.2); --border2: rgba(201,168,76,0.35);
    --text: #E8E4D8; --muted: rgba(232,228,216,0.45);
    --danger: #C0665A; --ok: #5A8A5A; --warn: #C9A84C;
    --mono: 'Share Tech Mono', monospace; --sans: 'Rajdhani', sans-serif;
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--mono); background: var(--navy); color: var(--text);
    min-height: 100vh; overflow-x: hidden;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(201,168,76,0.06) 1px, transparent 0);
    background-size: 32px 32px;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 2.5rem; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(13,17,23,0.95); border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }
  .nav-logo { font-family: var(--mono); font-size: 15px; letter-spacing: 6px; text-transform: uppercase; color: var(--text); }
  .nav-tag { font-family: var(--mono); font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 8rem 1.5rem 3rem; position: relative;
  }
  .hero-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 2rem;
    display: flex; align-items: center; gap: 16px;
  }
  .hero-label::before, .hero-label::after { content: ''; display: block; width: 40px; height: 1px; background: var(--gold-dim); }
  .hero h1 {
    font-family: var(--sans); font-size: clamp(36px, 5.5vw, 68px);
    font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    line-height: 1.05; margin-bottom: 0.5rem;
  }
  .hero h1 span { color: var(--gold); }
  .hero-sub-line {
    font-family: var(--mono); font-size: 11px; letter-spacing: 3px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 2.5rem;
  }
  .hero-desc {
    font-family: var(--mono); font-size: 12px; color: var(--muted);
    max-width: 480px; line-height: 1.8; margin-bottom: 3rem; letter-spacing: 0.5px;
  }

  /* INPUT */
  .input-card {
    width: 100%; max-width: 580px;
    border: 1px solid var(--border2); background: rgba(13,17,23,0.8);
    padding: 1.5rem;
  }
  .input-label { font-family: var(--mono); font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  .input-row { display: flex; gap: 8px; }
  .input-prefix { font-family: var(--mono); font-size: 11px; color: var(--muted); padding: 10px 0; flex-shrink: 0; }
  .domain-input {
    flex: 1; background: transparent; border: none; border-bottom: 1px solid var(--border2);
    color: var(--text); font-family: var(--mono); font-size: 13px;
    padding: 10px 8px; outline: none; letter-spacing: 1px;
    transition: border-color 0.2s;
  }
  .domain-input:focus { border-bottom-color: var(--gold); }
  .domain-input::placeholder { color: rgba(232,228,216,0.2); }
  .btn-analyze {
    background: transparent; color: var(--gold);
    border: 1px solid var(--border2); padding: 10px 20px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 3px;
    text-transform: uppercase; cursor: pointer; flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .btn-analyze:hover { background: var(--gold-glow); border-color: var(--gold); }
  .btn-analyze:disabled { opacity: 0.3; cursor: not-allowed; }

  .status-bar {
    width: 100%; max-width: 580px; margin-top: 1rem;
    font-family: var(--mono); font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gold);
    padding: 10px 14px; border: 1px solid var(--gold-dim);
    background: var(--gold-glow); display: none; align-items: center; gap: 10px;
  }
  .status-dot { width: 5px; height: 5px; background: var(--gold); flex-shrink: 0; animation: blink 1s step-end infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .error-bar {
    width: 100%; max-width: 580px; margin-top: 1rem;
    font-family: var(--mono); font-size: 11px; letter-spacing: 1px;
    color: var(--danger); padding: 10px 14px;
    border: 1px solid rgba(192,102,90,0.3); background: rgba(192,102,90,0.05);
    display: none;
  }

  /* FEATURES GRID */
  .features {
    width: 100%; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    display: grid; grid-template-columns: repeat(3, 1fr);
    position: relative; z-index: 1;
  }
  .feature-divider { font-family: var(--mono); font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); text-align: center; padding: 10px; border-bottom: 1px solid var(--border); grid-column: 1/-1; }
  .feature-tags { display: contents; }
  .feat-tag {
    padding: 14px 16px; border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    font-family: var(--mono); font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--text); text-align: center;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .feat-tag:nth-child(3n) { border-right: none; }
  .feat-tag::before { content: '•'; color: var(--gold); font-size: 14px; }

  /* REPORT */
  .report { max-width: 780px; margin: 0 auto; padding: 3rem 1.5rem 6rem; display: none; position: relative; z-index: 1; }
  .report-divider {
    display: flex; align-items: center; gap: 16px; margin-bottom: 2rem;
    font-family: var(--mono); font-size: 9px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--gold);
  }
  .report-divider::before, .report-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .panel { border: 1px solid var(--border); background: rgba(13,17,23,0.7); margin-bottom: 2px; }
  .panel-header {
    padding: 10px 16px; border-bottom: 1px solid var(--border);
    font-family: var(--mono); font-size: 9px; letter-spacing: 3px;
    text-transform: uppercase; color: var(--gold);
    display: flex; align-items: center; gap: 8px;
  }
  .panel-header::before { content: '//'; opacity: 0.5; }
  .panel-body { padding: 1.25rem 1.5rem; }
  .panel-group { margin-bottom: 1.5rem; }

  .report-meta { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 1px; margin-bottom: 8px; }
  .report-company { font-family: var(--sans); font-size: 28px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 4px; }
  .report-domain { font-family: var(--mono); font-size: 11px; color: var(--gold); letter-spacing: 2px; }

  .score-layout { display: flex; align-items: center; gap: 1.5rem; }
  .score-box {
    width: 80px; height: 80px; border: 1px solid; flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .score-num { font-family: var(--mono); font-size: 30px; line-height: 1; }
  .score-unit { font-family: var(--mono); font-size: 9px; opacity: 0.5; margin-top: 2px; letter-spacing: 1px; }
  .c-low { border-color: var(--ok); color: var(--ok); }
  .c-med { border-color: var(--warn); color: var(--warn); }
  .c-high { border-color: var(--danger); color: var(--danger); }
  .verdict-label { font-family: var(--mono); font-size: 12px; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 6px; }
  .verdict-desc { font-family: var(--mono); font-size: 11px; color: var(--muted); line-height: 1.7; letter-spacing: 0.5px; }

  .kv-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; }
  .kv-label { font-family: var(--mono); font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 4px; }
  .kv-value { font-family: var(--mono); font-size: 12px; line-height: 1.5; letter-spacing: 0.5px; }

  .bar-list { display: flex; flex-direction: column; gap: 1rem; }
  .bar-header { display: flex; justify-content: space-between; margin-bottom: 5px; }
  .bar-name { font-family: var(--mono); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; }
  .bar-score { font-family: var(--mono); font-size: 11px; }
  .bar-track { height: 2px; background: rgba(255,255,255,0.06); margin-bottom: 5px; }
  .bar-fill { height: 100%; transition: width 0.8s ease; }
  .bar-note { font-family: var(--mono); font-size: 10px; color: var(--muted); line-height: 1.65; letter-spacing: 0.5px; }

  .flag-list { display: flex; flex-direction: column; gap: 8px; }
  .flag-item {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 10px 12px; border: 1px solid rgba(192,102,90,0.25);
    background: rgba(192,102,90,0.04);
  }
  .flag-sq { width: 6px; height: 6px; background: var(--danger); flex-shrink: 0; margin-top: 4px; }
  .flag-text { font-family: var(--mono); font-size: 11px; line-height: 1.65; letter-spacing: 0.5px; }

  .step-list { display: flex; flex-direction: column; gap: 8px; }
  .step-item { display: flex; gap: 14px; align-items: flex-start; padding: 10px 12px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); }
  .step-n { font-family: var(--mono); font-size: 11px; color: var(--gold); flex-shrink: 0; min-width: 20px; }
  .step-text { font-family: var(--mono); font-size: 11px; line-height: 1.7; letter-spacing: 0.5px; }

  .conclusion-text { font-family: var(--mono); font-size: 12px; line-height: 1.85; letter-spacing: 0.5px; color: var(--text); }
  .report-footnote { font-family: var(--mono); font-size: 10px; color: var(--muted); line-height: 1.7; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); letter-spacing: 0.5px; }

  footer {
    border-top: 1px solid var(--border); padding: 1.25rem 2.5rem;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
    position: relative; z-index: 1;
  }
  footer span { font-family: var(--mono); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); }

  @media (max-width: 560px) {
    .input-row { flex-direction: column; }
    .btn-analyze { text-align: center; }
    .score-layout { flex-direction: column; text-align: center; }
    .features { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Averom</div>
  <div class="nav-tag">Supplier Risk Intelligence</div>
</nav>

<div class="hero">
  <div class="hero-label">AI-Powered Due Diligence</div>
  <h1>Know Your <span>Supplier</span><br />Before They Cost You.</h1>
  <div class="hero-sub-line">Supplier Risk Intelligence · Verify Before You Wire</div>
  <p class="hero-desc">Averom analyzes suppliers in seconds — flagging fraud signals, legitimacy gaps, and compliance risks before you commit capital or inventory.</p>

  <div class="input-card">
    <div class="input-label">Enter Supplier Domain</div>
    <div class="input-row">
      <span class="input-prefix">https://</span>
      <input class="domain-input" id="supplierInput" type="text" placeholder="supplynextwholesale.com" autocomplete="off" spellcheck="false" />
      <button class="btn-analyze" id="analyzeBtn">[ Analyze ]</button>
    </div>
  </div>
  <div class="status-bar" id="statusBar"><div class="status-dot"></div><span id="statusText">Initializing intelligence scan</span></div>
  <div class="error-bar" id="errorBar"></div>
</div>

<div class="features">
  <div class="feature-divider">Built for Ecommerce · B2B · Import &amp; Export</div>
  <div class="feat-tag">Domain &amp; Fraud Signal Analysis</div>
  <div class="feat-tag">Supplier Legitimacy Scoring</div>
  <div class="feat-tag">Ecommerce Compliance Risk</div>
  <div class="feat-tag">B2B &amp; Wholesale Vetting</div>
  <div class="feat-tag">Import / Export Due Diligence</div>
  <div class="feat-tag">Instant AI Reports</div>
</div>

<div class="report" id="report">
  <div class="report-divider">Intelligence Report</div>

  <div class="panel-group">
    <div class="panel">
      <div class="panel-header">Report Header</div>
      <div class="panel-body">
        <div class="report-meta" id="reportMeta"></div>
        <div class="report-company" id="reportCompany"></div>
        <div class="report-domain" id="reportDomain"></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">Overall Risk Score</div>
      <div class="panel-body">
        <div class="score-layout">
          <div class="score-box" id="scoreBox">
            <div class="score-num" id="scoreNum">—</div>
            <div class="score-unit">/ 10</div>
          </div>
          <div>
            <div class="verdict-label" id="verdictLabel"></div>
            <div class="verdict-desc" id="verdictDesc"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">Supplier Overview</div>
      <div class="panel-body"><div class="kv-grid" id="overviewGrid"></div></div>
    </div>
  </div>

  <div class="panel-group">
    <div class="panel">
      <div class="panel-header">Risk Indicator Breakdown</div>
      <div class="panel-body"><div class="bar-list" id="barList"></div></div>
    </div>
  </div>

  <div class="panel-group">
    <div class="panel">
      <div class="panel-header">Key Red Flags</div>
      <div class="panel-body"><div class="flag-list" id="flagList"></div></div>
    </div>
    <div class="panel">
      <div class="panel-header">Recommended Due Diligence</div>
      <div class="panel-body"><div class="step-list" id="stepList"></div></div>
    </div>
  </div>

  <div class="panel-group">
    <div class="panel">
      <div class="panel-header">Final Conclusion</div>
      <div class="panel-body">
        <div class="conclusion-text" id="conclusionText"></div>
        <div class="report-footnote" id="reportFootnote"></div>
      </div>
    </div>
  </div>
</div>

<footer>
  <span>© 2025 Averom · Denarius Black LLC</span>
  <span>AI Intelligence · Not Legal Advice</span>
</footer>

<script>
const STATUS=['Scanning domain registration records','Checking fraud databases','Searching BBB and business registry','Analyzing Amazon compliance signals','Cross-referencing review patterns','Verifying physical presence','Calculating weighted risk score','Generating intelligence report'];
let statusTimer;
function startStatus(){let i=0;const el=document.getElementById('statusText');document.getElementById('statusBar').style.display='flex';el.textContent=STATUS[0];statusTimer=setInterval(()=>{i=(i+1)%STATUS.length;el.textContent=STATUS[i];},2200);}
function stopStatus(){clearInterval(statusTimer);document.getElementById('statusBar').style.display='none';}
function scoreClass(s){return s<=3.5?'c-low':s<=6.5?'c-med':'c-high';}
function barColor(s){return s<=3?'#5A8A5A':s<=6?'#C9A84C':'#C0665A';}
function render(data){
  const ts=new Date();
  const id=`AVR-${ts.getFullYear()}${String(ts.getMonth()+1).padStart(2,'0')}${String(ts.getDate()).padStart(2,'0')}-${Math.floor(Math.random()*9000+1000)}`;
  document.getElementById('reportMeta').textContent=`${id} · ${ts.toLocaleString()}`;
  document.getElementById('reportCompany').textContent=data.company_name;
  document.getElementById('reportDomain').textContent=data.website;
  const box=document.getElementById('scoreBox');
  box.className='score-box '+scoreClass(data.overall_score);
  document.getElementById('scoreNum').textContent=Number(data.overall_score).toFixed(1);
  document.getElementById('verdictLabel').textContent=data.verdict;
  document.getElementById('verdictDesc').textContent=data.verdict_summary;
  document.getElementById('overviewGrid').innerHTML=[['Company',data.company_name],['Website',data.website],['Address',data.address],['Domain Age',data.domain_age],['Category',data.business_category]].map(([l,v])=>`<div><div class="kv-label">${l}</div><div class="kv-value">${v||'—'}</div></div>`).join('');
  document.getElementById('barList').innerHTML=(data.categories||[]).map(c=>{const pct=Math.round((c.score/10)*100);const col=barColor(c.score);return`<div><div class="bar-header"><span class="bar-name">${c.name}</span><span class="bar-score" style="color:${col}">${Number(c.score).toFixed(1)} / 10</span></div><div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${col}"></div></div><div class="bar-note">${c.explanation}</div></div>`;}).join('');
  document.getElementById('flagList').innerHTML=(data.red_flags||[]).length?data.red_flags.map(f=>`<div class="flag-item"><div class="flag-sq"></div><div class="flag-text">${f}</div></div>`).join(''):'<div class="flag-text" style="color:var(--muted)">No major red flags identified.</div>';
  document.getElementById('stepList').innerHTML=(data.due_diligence_steps||[]).map((s,i)=>`<div class="step-item"><div class="step-n">[${i+1}]</div><div class="step-text">${s}</div></div>`).join('');
  document.getElementById('conclusionText').textContent=data.conclusion;
  document.getElementById('reportFootnote').textContent=`// ${data.data_sources_note||'Report generated via AI-assisted web intelligence.'} · Not legal or financial advice.`;
  document.getElementById('report').style.display='block';
  document.getElementById('report').scrollIntoView({behavior:'smooth',block:'start'});
}
async function runAnalysis(){
  const raw=document.getElementById('supplierInput').value.trim();
  if(!raw)return;
  const supplier=raw.replace(/^https?:\/\//i,'').replace(/\/.*$/,'');
  const btn=document.getElementById('analyzeBtn');
  const errEl=document.getElementById('errorBar');
  btn.disabled=true;errEl.style.display='none';document.getElementById('report').style.display='none';
  startStatus();
  try{
    const res=await fetch('/api/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({supplier})});
    const data=await res.json();
    if(!res.ok)throw new Error(data.error||'Analysis failed');
    stopStatus();render(data);
  }catch(err){stopStatus();errEl.textContent='// Error: '+err.message;errEl.style.display='block';}
  finally{btn.disabled=false;}
}
document.getElementById('analyzeBtn').addEventListener('click',runAnalysis);
document.getElementById('supplierInput').addEventListener('keydown',e=>{if(e.key==='Enter')runAnalysis();});
</script>
</body>
</html>
